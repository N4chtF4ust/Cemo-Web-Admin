rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());

      // Creation: Users can create their own profile, but MUST be a 'USER'
      allow create: if request.auth != null && 
                    request.auth.uid == userId && 
                    request.resource.data.role == 'USER';

      // Update: 
      allow update: if request.auth != null && (
        (request.auth.uid == userId && request.resource.data.role == resource.data.role) ||
        isAdmin()
      );

      // Deletion: Only admins can delete users
      allow delete: if isAdmin();

      // Waste Entries Subcollection (Corrected name)
      match /waste_entries/{entryId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }
  }
}
